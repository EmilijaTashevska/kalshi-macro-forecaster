# Copy this file to .env and fill in your keys. .env is gitignored.
# You do NOT need most of these for Phase 0. They are added as we hit
# the relevant phases.

# ── Phase 1.2: FRED / ALFRED ──
# Get one for free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── Phase 1.3: BLS (Bureau of Labor Statistics) ──
# Get one for free at https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# ── Phase 1.3: BEA (Bureau of Economic Analysis) ──
# Get one for free at https://apps.bea.gov/API/signup/
BEA_API_KEY=

# ── Phase 1.5: Kalshi ──
# https://kalshi.com — for our needs the public endpoints work
# without auth, but a key enables higher rate limits.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# ── Phase 3: LLM baselines (paid, cheap) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Phase 5+: Experiment tracking (optional, free tier) ──
WANDB_API_KEY=

# ── Phase 5+: GPU training (RunPod / Lambda) ──
# Filled in as needed.

# ── Database ──
KALSHI_TRAIN_DB_PATH=data/kalshi_train.db
KALSHI_TRAIN_LOG_LEVEL=INFO
